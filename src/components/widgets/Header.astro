---
const primaryNav = [
  { label: "Главная", href: "#" },
  { label: "ENERGO FOOD", href: "#" },
  { label: "ENERGO PROGRESS", href: "#" },
  { label: "VLADIVOSTOK", href: "#" },
  { label: "COFFEE MAESTRO", href: "#" },
];

const secondaryNav = [
  { label: "Eto Syrnik", href: "#" },
  { label: "Поставки в ритейл", href: "#" },
  { label: "Франшиза Energo Street Food", href: "/franchise" },
];

const allNav = [
  ...primaryNav.map((item, index) => ({ ...item, primary: index === 0 })),
  ...secondaryNav.map((item) => ({ ...item, primary: false })),
];
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 shadow-sm backdrop-blur">
  <div class="container py-4">
    <div class="flex items-center justify-between gap-3 md:block">
      <a href="#" class="block shrink-0 text-lg font-black tracking-wide text-foreground-accent md:text-xl lg:text-2xl">
        ENERGO FOOD GROUP
      </a>

      <nav aria-label="Основная навигация" class="mt-4 hidden md:block">
        <ul class="flex flex-nowrap items-center gap-2 whitespace-nowrap">
          {
            allNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "rounded-lg px-3 py-2 text-sm font-semibold transition-colors",
                    item.primary
                      ? "bg-slate-900 text-white hover:bg-slate-700"
                      : "text-slate-700 hover:bg-slate-100 hover:text-slate-900",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <details class="relative md:hidden">
        <summary class="cursor-pointer list-none rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">
          Меню
        </summary>

        <nav
          aria-label="Мобильная навигация"
          class="absolute right-0 top-12 z-50 w-80 max-w-[calc(100vw-1.5rem)] rounded-xl border border-slate-200 bg-white p-2 shadow-lg"
        >
          <ul class="flex flex-col gap-1">
            {
              allNav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      "block rounded-lg px-3 py-2 text-sm font-semibold transition-colors",
                      item.primary
                        ? "bg-slate-900 text-white hover:bg-slate-700"
                        : "text-slate-700 hover:bg-slate-100 hover:text-slate-900",
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </details>
    </div>
  </div>
</header>

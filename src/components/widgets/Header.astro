---
import logoImg from "../../assets/img-logo.png";

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";

const primaryNav = [
  { label: "Главная", href: "/" },
];

const secondaryNav = [
  { label: "Eto Syrnik", href: "/eto-syrnik" },
  { label: "Поставки в ритейл", href: "/retail-supplies" },
  { label: "Франшиза Energo Street Food", href: "/franchise" },
];

const allNav = [
  ...primaryNav.map((item, index) => ({ ...item, primary: index === 0 })),
  ...secondaryNav.map((item) => ({ ...item, primary: false })),
];
---

<header
  id="floating-header"
  class="fixed left-1/2 top-3 z-50 w-[min(1200px,calc(100%-1rem))] -translate-x-1/2 transition-opacity duration-300 ease-out"
>
  <div class="rounded-2xl relative border border-slate-200/90 bg-white/90 px-3 py-2 shadow-lg backdrop-blur">
    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href="/"
        class="shrink-0 rounded-lg px-2 py-2 outline-offset-2 focus-visible:outline-2 focus-visible:outline-slate-900 sm:px-3"
      >
        <img
          src={logoImg.src}
          width={logoImg.width}
          height={logoImg.height}
          alt="Energo Food — Group of Companies"
          class="h-8 w-auto sm:h-9"
          loading="eager"
          decoding="async"
        />
      </a>

      <nav aria-label="Основная навигация" class="min-w-0 flex-1">
        <ul
          class="flex flex-wrap items-center justify-end gap-x-1 gap-y-1 sm:gap-x-1.5 sm:whitespace-nowrap"
        >
          {
            allNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "block rounded-lg px-2 py-1.5 text-[11px] font-semibold leading-tight transition-colors sm:px-2.5 sm:py-2 sm:text-xs md:text-sm",
                    pathname === item.href
                      ? "bg-slate-900 text-white hover:bg-slate-700"
                      : "text-slate-700 hover:bg-slate-100 hover:text-slate-900",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("floating-header");
  let lastScrollY = window.scrollY;

  const showHeader = () => {
    if (!header) return;
    header.classList.remove("opacity-0", "pointer-events-none");
    header.classList.add("opacity-100");
  };

  const hideHeader = () => {
    if (!header) return;
    header.classList.remove("opacity-100");
    header.classList.add("opacity-0", "pointer-events-none");
  };

  window.addEventListener(
    "scroll",
    () => {
      const currentY = window.scrollY;

      if (currentY <= 200) {
        showHeader();
      } else if (currentY > lastScrollY + 2) {
        hideHeader();
      } else if (currentY < lastScrollY - 2) {
        showHeader();
      }

      lastScrollY = currentY;
    },
    { passive: true },
  );
</script>

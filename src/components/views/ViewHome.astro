---
import welcomeImage from "../../assets/img-welcome.png";
import imageProjects from "../../assets/img-projects.jpg";
import imgProject1 from "../../assets/img-project-1.png";
import imgProject2 from "../../assets/img-project-2.png";
---

<div class="container py-6 sm:py-8 md:py-12">
  <div class="overflow-hidden rounded-xl bg-white sm:rounded-2xl">
    <img src={welcomeImage.src} width={welcomeImage.width} height={welcomeImage.height} alt="Energo Food Group of companies" loading="eager" class="mx-auto block h-auto w-full object-contain" />
    <div class="text-lg md:text-3xl font-light">
      <div class="m-auto w-full max-w-4xl text-center">
        <div>Наша компания занимается производством продуктов питания, оптовой и розничной торговлей, экспортом, импортом и управлением бизнеса в сфере общественного питания.</div>
      </div>
    </div>
  </div>
</div>

<div>
  <div class="relative flex h-[60vh] min-h-[300px] items-center justify-center bg-black py-10">
    <img class="absolute inset-0 h-full w-full object-cover" src={imageProjects.src} width={imageProjects.width} height={imageProjects.height} alt="" />
    <div class="absolute inset-0 h-full w-full bg-black/70"></div>
    <div class="relative pb-10 pt-6 text-center text-lg md:text-3xl lg:text-7xl font-semibold text-white" id="div-1">НАШИ ПРОЕКТЫ</div>
    <svg role="presentation" class="absolute bottom-5 left-1/2 z-10 -translate-x-1/2" style="fill:#ffffff;" x="0px" y="0px" width="38.417px" height="18.592px" viewBox="0 0 38.417 18.592"
      ><g
        ><path
          d="M19.208,18.592c-0.241,0-0.483-0.087-0.673-0.261L0.327,1.74c-0.408-0.372-0.438-1.004-0.066-1.413c0.372-0.409,1.004-0.439,1.413-0.066L19.208,16.24L36.743,0.261c0.411-0.372,1.042-0.342,1.413,0.066c0.372,0.408,0.343,1.041-0.065,1.413L19.881,18.332C19.691,18.505,19.449,18.592,19.208,18.592z"
        ></path></g
      ></svg
    >
  </div>

  <section class="container py-8 sm:py-10 md:py-12">
    <div class="mx-auto grid max-w-4xl grid-cols-1 gap-5 sm:gap-6 md:grid-cols-2">
      <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <img src={imgProject1.src} width={imgProject1.width} height={imgProject1.height} alt="Energo Food" class="aspect-video w-full rounded-xl object-cover" loading="lazy" />
        <h3 class="mt-3 text-xl font-extrabold text-slate-900">ENERGO FOOD</h3>
        <p class="mt-1 min-h-12 text-sm leading-6 text-slate-600">Производство продуктов питания для ритейла в Королевстве Таиланд</p>
        <a href="#" class="mt-3 inline-flex rounded-full bg-black px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-slate-800"> Больше о проекте </a>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <img src={imgProject2.src} width={imgProject2.width} height={imgProject2.height} alt="Energo Progress" class="aspect-video w-full rounded-xl object-cover" loading="lazy" />
        <h3 class="mt-3 text-xl font-extrabold text-slate-900">Energo Progress</h3>
        <p class="mt-1 min-h-12 text-sm leading-6 text-slate-600">Дистрибьюция и реклама. <br> @energo_progress_thai</p>
        <a href="#" class="mt-3 inline-flex rounded-full bg-black px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-slate-800"> Больше о проекте </a>
      </article>
    </div>
  </section>
</div>

<footer class="border-t border-slate-200 bg-white py-10">
  <div class="container">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-3xl">
        <div class="text-lg font-semibold text-slate-900">ENERGO FOOD GROP CO.,LTD.</div>
        <div class="mt-1 text-sm text-slate-600">Tax ID: 0835568021786</div>
        <div class="mt-2 text-sm leading-6 text-slate-600">Address: 221/35 Moo 3, Si Sunthon Subdistrict, Thalang District, Phuket 83110</div>
      </div>

      <div class="sm:text-right">
        <div class="text-sm font-semibold text-slate-900">Phone</div>
        <a href="tel:+66654869537" class="mt-1 inline-block text-sm text-slate-600 transition-colors hover:text-slate-900">
          +66654869537
        </a>
      </div>
    </div>
  </div>
</footer>

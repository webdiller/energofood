---
import welcomeImage from "../../assets/img-welcome.png";
import imgProjectEtoSyrnik from "../../assets/img-eto-syrnik-circle.png";
import imgProjectRetail from "../../assets/img-retail-circle.png";
import imgProjectFranchise from "../../assets/img-energo-street-food-circle.png";
import directorImage from "../../assets/img-director.jpg";
import imageProjects from "../../assets/img-projects.jpg";
import "photoswipe/style.css";

const projects = [
  {
    title: "Eto Syrnik",
    description: "Производство и поставка сырников в кафе, рестораны, сауны и другие заведения.",
    href: "/eto-syrnik",
    image: imgProjectEtoSyrnik,
    alt: "Eto Syrnik",
  },
  {
    title: "Поставки в ритейл",
    description: "Поставки продукции ENERGO FOOD GROUP в ритейл.",
    href: "/retail-supplies",
    image: imgProjectRetail,
    alt: "Поставки в ритейл",
  },
  {
    title: "Франшиза Energo Street Food",
    description: "Презентационные материалы и информация по франшизе Energo Street Food.",
    href: "/franchise",
    image: imgProjectFranchise,
    alt: "Франшиза Energo Street Food",
  },
];
---

<div class="container max-w-none py-6 sm:py-8 md:py-12 lg:pb-20">
  <div class="overflow-hidden rounded-xl bg-white sm:rounded-2xl">
    <img src={welcomeImage.src} width={welcomeImage.width} height={welcomeImage.height} alt="Energo Food Group of companies" loading="eager" class="mx-auto block h-auto w-full object-contain" />
    <div class="text-lg md:text-3xl font-light">
      <div class="mx-auto max-w-4xl w-full text-balance text-center">
        <div>Наша компания занимается производством продуктов питания, оптовой и розничной торговлей, экспортом, импортом и управлением бизнеса в сфере общественного питания.</div>
      </div>
    </div>
  </div>
</div>

<div>
  <div class="relative flex h-[60vh] min-h-[300px] items-center justify-center bg-black py-10">
    <img class="absolute inset-0 h-full w-full object-cover" src={imageProjects.src} width={imageProjects.width} height={imageProjects.height} alt="" />
    <div class="absolute inset-0 h-full w-full bg-black/70"></div>
    <div class="relative pb-10 pt-6 text-center text-lg md:text-3xl lg:text-7xl font-semibold text-white" id="div-1">НАШИ ПРОЕКТЫ</div>
    <a class="absolute bottom-5 left-1/2 z-10 -translate-x-1/2" href="#projects">
      <svg role="presentation" class="" style="fill:#ffffff;" x="0px" y="0px" width="38.417px" height="18.592px" viewBox="0 0 38.417 18.592"
        ><g
          ><path
            d="M19.208,18.592c-0.241,0-0.483-0.087-0.673-0.261L0.327,1.74c-0.408-0.372-0.438-1.004-0.066-1.413c0.372-0.409,1.004-0.439,1.413-0.066L19.208,16.24L36.743,0.261c0.411-0.372,1.042-0.342,1.413,0.066c0.372,0.408,0.343,1.041-0.065,1.413L19.881,18.332C19.691,18.505,19.449,18.592,19.208,18.592z"
          ></path></g
        ></svg
      >
    </a>
  </div>

  <section id="projects" class="container py-8 sm:py-10 md:py-12">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-5 sm:gap-6 md:grid-cols-3">
      {
        projects.map((project) => (
          <article class="flex flex-col items-center rounded-2xl bg-white p-4 text-center">
            <img src={project.image.src} width={project.image.width} height={project.image.height} alt={project.alt} class="aspect-square w-full rounded-xl object-cover" loading="lazy" />
            <h3 class="mt-3 text-3xl md:text-4xl font-bold text-slate-900">{project.title}</h3>
            <p class="mt-1 min-h-12 text-sm leading-6 text-slate-600 text-balance">{project.description}</p>
            <a href={project.href} class="mt-3 inline-flex rounded-full bg-black px-4 min-h-11 items-center justify-center py-2 text-sm font-semibold text-white transition-colors hover:bg-slate-800">
              Больше о проекте
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="container py-8 sm:py-10 md:py-12">
    <div class="mx-auto flex max-w-3xl flex-col items-center gap-5 rounded-3xl bg-white p-5 text-center sm:gap-6 sm:p-7">
      <div id="director-gallery" class="w-full max-w-2xl">
        <a
          href={directorImage.src}
          data-pswp-width={directorImage.width}
          data-pswp-height={directorImage.height}
          class="block overflow-hidden rounded-2xl"
          aria-label="Открыть фото директора"
        >
          <img
            src={directorImage.src}
            width={directorImage.width}
            height={directorImage.height}
            alt="Прозоров Артем Владимирович"
            class="aspect-4/3 w-full rounded-2xl object-cover"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>

      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Руководство</p>
        <h2 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">Прозоров Артем Владимирович</h2>
        <p class="mt-2 text-base leading-7 text-slate-700 sm:text-lg">Директор холдинга Energo Food Group</p>

        <div class="flex items-center justify-center gap-2 sm:gap-4 mt-4 flex-col sm:flex-row">
          <div class="mt-1 flex flex-wrap items-center justify-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-phone-call-icon lucide-phone-call"
              ><path d="M13 2a9 9 0 0 1 9 9"></path><path d="M13 6a5 5 0 0 1 5 5"></path><path
                d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"
              ></path></svg
            >
            <a href="tel:+66832202051" class="text-sm underline-offset-2 transition-colors hover:underline"> +66832202051 </a>
          </div>
          <div class="mt-1 flex flex-wrap items-center justify-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-mail-icon lucide-mail"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg
            >
            <a href="mailto:Energofoodgroup@gmail.com" class="text-sm underline-offset-2 transition-colors hover:underline"> Energofoodgroup@gmail.com </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { initPhotoSwipeGallery } from "../widgets/init-photoswipe";
    initPhotoSwipeGallery("director-gallery");
  </script>
</div>

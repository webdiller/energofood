---
import welcomeImage from "../../assets/img-welcome.png";
import imgProjectEtoSyrnik from "../../assets/img-eto-syrnik-circle.png";
import imgProjectRetail from "../../assets/img-retail-circle.png";
import imgProjectFranchise from "../../assets/img-energo-street-food-circle.png";
import directorImage from "../../assets/img-director.jpg";
import "photoswipe/style.css";

const projects = [
  {
    title: "Eto Syrnik",
    description: "Производство и поставка сырников в кафе, рестораны, сауны и другие заведения.",
    href: "/eto-syrnik",
    image: imgProjectEtoSyrnik,
    alt: "Eto Syrnik",
  },
  {
    title: "Retail Supplies",
    description: "Поставки продукции ENERGO FOOD GROUP в ритейл.",
    href: "/retail-supplies",
    image: imgProjectRetail,
    alt: "Retail Supplies",
  },
  {
    title: "Franchise",
    description: "Презентационные материалы и информация по франшизе Energo Street Food.",
    href: "/franchise",
    image: imgProjectFranchise,
    alt: "Franchise",
  },
];
---

<div class="container max-w-none py-6 sm:py-8 md:py-12 lg:pb-20">
  <div class="overflow-hidden rounded-xl bg-white sm:rounded-2xl">
    <img src={welcomeImage.src} width={welcomeImage.width} height={welcomeImage.height} alt="Energo Food Group of companies" loading="eager" class="mx-auto block h-auto w-full object-contain" />
    <div class="text-lg md:text-3xl font-light">
      <div class="mx-auto max-w-4xl w-full text-balance text-center">
        <div>Наша компания занимается производством продуктов питания, оптовой и розничной торговлей, экспортом, импортом и управлением бизнеса в сфере общественного питания.</div>
      </div>
    </div>
  </div>
</div>

<section class="container py-8 sm:py-10 md:py-12">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-5 sm:gap-6 md:grid-cols-3">
    {projects.map((project) => (
      <article class="flex flex-col items-center rounded-2xl bg-white p-4 text-center">
        <img src={project.image.src} width={project.image.width} height={project.image.height} alt={project.alt} class="aspect-square w-full rounded-xl object-cover" loading="lazy" />
        <h3 class="mt-3 text-3xl md:text-4xl font-bold text-slate-900">{project.title}</h3>
        <p class="mt-1 min-h-12 text-sm leading-6 text-slate-600 text-balance">{project.description}</p>
        <a href={project.href} class="mt-3 inline-flex rounded-full bg-black px-4 min-h-11 items-center justify-center py-2 text-sm font-semibold text-white transition-colors hover:bg-slate-800">Больше о проекте</a>
      </article>
    ))}
  </div>
</section>

<section class="container py-8 sm:py-10 md:py-12">
  <div id="director-gallery" class="mx-auto flex max-w-3xl flex-col items-center gap-5 rounded-3xl bg-white p-5 text-center sm:gap-6 sm:p-7">
    <a
      href={directorImage.src}
      data-pswp-width={directorImage.width}
      data-pswp-height={directorImage.height}
      class="block w-full max-w-2xl overflow-hidden rounded-2xl"
      aria-label="Открыть фото директора"
    >
      <img
        src={directorImage.src}
        width={directorImage.width}
        height={directorImage.height}
        alt="Прозоров Артем Владимирович"
        class="aspect-[4/3] w-full rounded-2xl object-cover"
        loading="lazy"
        decoding="async"
      />
    </a>

    <div class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Руководство</p>
      <h2 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">Прозоров Артем Владимирович</h2>
      <p class="mt-2 text-base leading-7 text-slate-700 sm:text-lg">Директор холдинга Energo Food Group</p>
    </div>
  </div>
</section>

<script>
  import { initPhotoSwipeGallery } from "../widgets/init-photoswipe";
  initPhotoSwipeGallery("director-gallery");
</script>

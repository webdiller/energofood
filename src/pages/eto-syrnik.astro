---
import Layout from "../layouts/Layout.astro";

import imgSyrnik from "../assets/img-eto-syrnik.jpg";
import parashutVideo from "../assets/parashut.MOV";
import imgSyrnik1 from "../assets/products/1.jpeg";
import imgSyrnik5 from "../assets/products/5.jpeg";
import "photoswipe/dist/photoswipe.css";

const assortment = [
  "Сырники классические",
  "Сырники с начинкой карамельные",
  "Сырники с начинкой шоколадные",
  "Сырники с начинкой грушевые",
  "Сырники с начинкой с арахисовой пастой",
  "Сырники с начинкой со шпинатом и сыром Чеддер",
  "Сырники с начинкой с базиликом и моццареллой",
  "Сырники с начинкой со сгущенкой",
];

const gallery = [imgSyrnik1, imgSyrnik5].map((n) => ({
  id: n,
  src: n.src,
  w: n.width ?? 1200,
  h: n.height ?? 800,
}));
---

<Layout>
  <section class="py-12 sm:py-14">
    <div class="mx-auto max-w-6xl px-3 lg:px-4">
      <div class="flex flex-col gap-3 items-center justify-center">
        <img src={imgSyrnik.src} alt="Логотип Eto Syrnik" width={imgSyrnik.width} height={imgSyrnik.height} class="h-auto w-full max-w-2xl rounded-3xl border border-slate-200 bg-slate-900/5 p-2" />
      </div>

      <p class="text-lg md:text-3xl font-light text-center my-10">Производство и поставка сырников в кафе, рестораны, сауны и другие заведения.</p>

      <div class="mt-8 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <button
          type="button"
          id="eto-syrnik-video-trigger"
          class="group relative block aspect-video w-full cursor-pointer"
          aria-label="Открыть видео"
        >
          <video
            src={parashutVideo}
            muted
            loop
            autoplay
            playsinline
            preload="metadata"
            class="h-full w-full object-cover"
          ></video>
          <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/20 transition-colors group-hover:bg-black/30">
            <div class="rounded-full bg-white/90 px-5 py-2 text-sm font-bold text-slate-900">Смотреть видео</div>
          </div>
        </button>
      </div>

      <div class="mt-10">
        <h2 class="text-lg md:text-3xl font-semibold text-left mt-10">Ассортимент</h2>

        <ul class="mt-4 list-disc pl-5 text-base font-semibold leading-7 text-slate-800">
          {assortment.map((t) => <li>{t}</li>)}
        </ul>
      </div>

      <div class="mt-10">
        <h2 class="text-lg md:text-3xl font-semibold text-left my-10">Фотографии сырников в упаковках</h2>

        <div id="eto-syrnik-gallery" class="mt-6 grid grid-cols-2 gap-4" aria-label="Галерея упаковок Eto Syrnik">
          {
            gallery.map((img) => (
              <a href={img.src} data-pswp-width={img.w} data-pswp-height={img.h} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm" aria-label="Открыть фотографию">
                <img src={img.src} width={img.w} height={img.h} alt="Сырники в упаковке" loading="lazy" class="aspect-video object-cover transition-transform duration-300 group-hover:scale-[1.03]" />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <div id="eto-syrnik-video-modal" class="fixed inset-0 z-110 hidden items-center justify-center bg-black/80 p-4">
    <div class="w-screen">
      <video
        id="eto-syrnik-video-modal-player"
        src={parashutVideo}
        controls
        playsinline
        preload="metadata"
        class="max-h-[90vh] w-full bg-black object-contain"
      ></video>
      <div class="mt-3 flex justify-end">
        <button
          type="button"
          id="eto-syrnik-video-close"
          class="rounded-lg bg-white px-4 py-2 text-sm font-bold text-slate-900"
        >
          Закрыть
        </button>
      </div>
    </div>
  </div>

  <script>
    import { initPhotoSwipeGallery } from "../components/widgets/init-photoswipe";
    initPhotoSwipeGallery("eto-syrnik-gallery");
  </script>
  <script type="module">
    const trigger = document.getElementById("eto-syrnik-video-trigger");
    const modal = document.getElementById("eto-syrnik-video-modal");
    const closeBtn = document.getElementById("eto-syrnik-video-close");
    const player = document.getElementById("eto-syrnik-video-modal-player");

    if (trigger && modal && closeBtn && player instanceof HTMLVideoElement) {
      const openModal = () => {
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        player.currentTime = 0;
        void player.play();
      };

      const closeModal = () => {
        player.pause();
        modal.classList.add("hidden");
        modal.classList.remove("flex");
      };

      trigger.addEventListener("click", openModal);
      closeBtn.addEventListener("click", closeModal);

      modal.addEventListener("click", (event) => {
        if (event.target === modal) {
          closeModal();
        }
      });

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !modal.classList.contains("hidden")) {
          closeModal();
        }
      });
    }
  </script>
</Layout>

---
import imgSyrnik from "../assets/img-retail-circle.png";
import img1 from "../assets/prezentation/1.jpeg";
import img2 from "../assets/prezentation/2.jpeg";
import img3 from "../assets/prezentation/3.jpeg";
import img4 from "../assets/prezentation/4.jpeg";
import img5 from "../assets/prezentation/5.jpeg";
import img6 from "../assets/prezentation/6.jpeg";
import img7 from "../assets/prezentation/7.jpeg";
import img8 from "../assets/prezentation/8.jpeg";
import Layout from "../layouts/Layout.astro";

import "photoswipe/dist/photoswipe.css";

const images = [img1, img2, img3, img4, img5, img6, img7, img8];
---

<Layout title="Франшиза Energo Street Food | ENERGO FOOD GROUP" description="Презентационные материалы и галерея по франшизе Energo Street Food.">
  <div class="container max-w-4xl py-10 sm:py-12">
    <div class="flex flex-col gap-3 items-center justify-center">
      <img src={imgSyrnik.src} alt="Логотип Eto Syrnik" width={imgSyrnik.width} height={imgSyrnik.height} class="h-auto w-full max-w-xl" />
    </div>

    <h1 class="text-3xl text-center font-extrabold tracking-tight text-slate-900">Франшиза Energo Street Food</h1>
    <p class="text-lg md:text-3xl font-light text-center my-10">Презентационные материалы для знакомства с концепцией и форматами.вляет их на полки магазинов в ритейл</p>

    <div id="franchise-gallery" class="mt-8 grid grid-cols-1 gap-4" aria-label="Галерея презентации">
      {
        images.map((img, idx) => (
          <a
            href={img.src}
            data-pswp-width={img.width}
            data-pswp-height={img.height}
            class="group relative overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"
            aria-label={`Открыть изображение ${idx + 1}`}
          >
            <img
              src={img.src}
              width={img.width}
              height={img.height}
              alt={`Презентация ${idx + 1}`}
              loading="lazy"
              class="w-full h-auto object-contain transition-transform duration-300 group-hover:scale-105"
            />
          </a>
        ))
      }
    </div>
  </div>

  <script>
    import { initPhotoSwipeGallery } from "../components/widgets/init-photoswipe";
    initPhotoSwipeGallery("franchise-gallery");
  </script>
</Layout>

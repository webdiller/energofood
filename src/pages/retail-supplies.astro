---
import Layout from "../layouts/Layout.astro";
import imgSyrniki from "../assets/products/1.jpeg";
import photoswipeInitUrl from "../components/widgets/retail-photoswipe.ts?url";

import "photoswipe/style.css";

const placeholder = (label: string) => {
  const svg = `
    <svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
      <rect x="0" y="0" width="1200" height="800" fill="#F1F5F9" stroke="#CBD5E1" stroke-width="4"/>
      <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle"
        font-family="Arial, sans-serif" font-size="64" fill="#64748B">${label}</text>
    </svg>
  `.trim();

  return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
};

const items = [
  { title: "сырники", img: imgSyrniki },
  { title: "рыба в упаковке", img: null },
  { title: "осьминог в упаковке", img: null },
];
---

<Layout>
  <section class="py-12 sm:py-14">
    <div class="mx-auto max-w-4xl px-3 lg:px-4">
      <p class="text-base font-semibold leading-7 text-slate-800 sm:text-lg">
        Energo Food Group производит продукты питания и поставляет их на полки магазинов в ритейл
      </p>

      <div id="retail-gallery" class="mt-8 space-y-8" aria-label="Галерея поставок в ритейл">
        {items.map((item) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">{item.title}</h2>

            <div class="mt-4 overflow-hidden rounded-xl border border-slate-100 bg-slate-50">
              <a
                href={item.img ? item.img.src : placeholder(item.title)}
                data-pswp-width={item.img?.width ?? 1200}
                data-pswp-height={item.img?.height ?? 800}
                class="block"
                aria-label={`Открыть изображение: ${item.title}`}
              >
                <img
                  src={item.img ? item.img.src : placeholder(item.title)}
                  alt={`Изображение: ${item.title}`}
                  width={item.img?.width ?? 1200}
                  height={item.img?.height ?? 800}
                  class="block h-auto w-full object-cover"
                  loading="lazy"
                />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script type="module" src={photoswipeInitUrl}></script>
</Layout>

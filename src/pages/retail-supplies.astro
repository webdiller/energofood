---
import Layout from "../layouts/Layout.astro";
import imgSyrnik from "../assets/img-retail-circle.png";
import imgSyrniki1 from "../assets/products/1.jpeg";
import imgSyrniki2 from "../assets/products/5.jpg";
import imgOktopus1 from "../assets/products/2.jpeg";
import imgFish1 from "../assets/products/3.jpeg";
import imgFish2 from "../assets/products/4.jpeg";
import "photoswipe/style.css";

const items = [
  { title: "Сырники с начинкой", images: [imgSyrniki1, imgSyrniki2] },
  { title: "Осьминог в упаковке", images: [imgOktopus1] },
  { title: "Рыба в упаковке", images: [imgFish1, imgFish2] },
];
---

<Layout
  title="Поставки в ритейл | ENERGO FOOD GROUP"
  description="Поставки продукции ENERGO FOOD GROUP в ритейл: фото и направления ассортимента."
>
  <section class="py-12 sm:py-14">
    <div class="mx-auto max-w-4xl px-3 lg:px-4">

      <div class="flex flex-col gap-3 items-center justify-center">
        <img src={imgSyrnik.src} alt="Логотип Eto Syrnik" width={imgSyrnik.width} height={imgSyrnik.height} class="h-auto w-full max-w-[700px]" />
      </div>

      <p class="text-lg md:text-3xl font-light text-center my-10">        Energo Food Group производит продукты питания и поставляет их на полки магазинов в ритейл
      </p>


      <div id="retail-gallery" class="mt-8 space-y-8" aria-label="Галерея поставок в ритейл">
        {items.map((item) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl first-letter:uppercase font-semibold tracking-tight text-slate-900">{item.title}</h2>

            <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
              {item.images.map((image, idx) => (
                <a
                  href={image.src}
                  data-pswp-width={image.width}
                  data-pswp-height={image.height}
                  class="overflow-hidden rounded-xl border border-slate-100 bg-slate-50"
                  aria-label={`Открыть изображение: ${item.title} ${idx + 1}`}
                >
                  <img
                    src={image.src}
                    alt={`Изображение: ${item.title} ${idx + 1}`}
                    width={image.width}
                    height={image.height}
                    class="block aspect-square object-center object-cover"
                    loading="lazy"
                  />
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script>
    import { initPhotoSwipeGallery } from "../components/widgets/init-photoswipe";
    initPhotoSwipeGallery("retail-gallery");
  </script>
</Layout>
